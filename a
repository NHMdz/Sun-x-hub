local function NewPage()
    local scroll = Instance.new("ScrollingFrame")
    scroll.Size                    = UDim2.new(1, 0, 1, 0)
    scroll.BackgroundTransparency  = 1
    scroll.BorderSizePixel         = 0
    scroll.ScrollBarThickness      = 4
    scroll.ScrollBarImageColor3    = Theme.ScrollBar
    scroll.CanvasSize              = UDim2.new(0, 0, 0, 0)
    scroll.AutomaticCanvasSize     = Enum.AutomaticSize.Y
    scroll.Visible                 = false
    scroll.Parent                  = ContentArea

    local list = Instance.new("UIListLayout")
    list.SortOrder = Enum.SortOrder.LayoutOrder
    list.Padding   = UDim.new(0, 6)
    list.Parent    = scroll

    MakePadding(scroll, 12, 12, 14, 14)
    return scroll
end

local function SetPage(page)
    for _, p in pairs(Pages) do p.Visible = false end
    for btn, pg in pairs(TabButtons) do
        if pg == page then
            Tween(btn, {BackgroundColor3 = Theme.TabActive}, 0.18)
            btn.TextColor3 = Theme.Text
        else
            Tween(btn, {BackgroundColor3 = Theme.TabInactive}, 0.18)
            btn.TextColor3 = Theme.TextDim
        end
    end
    page.Visible = true
    ActiveTab = page
end

local function AddTab(name, icon)
    local page = NewPage()
    table.insert(Pages, page)

    local btn = Button(TabListFrame, (icon or "◈") .. "  " .. name, UDim2.new(1, 0, 0, 34))
    btn.BackgroundColor3 = Theme.TabInactive
    btn.TextColor3       = Theme.TextDim
    btn.TextSize         = 13
    btn.Font             = Enum.Font.GothamBold
    btn.TextXAlignment   = Enum.TextXAlignment.Left
    btn.ZIndex           = 5
    MakeCorner(btn, 7)
    MakePadding(btn, 0, 0, 10, 8)

    local ActiveIndicator = Frame(btn, UDim2.new(0, 3, 0, 18), UDim2.new(0, 0, 0.5, -9), Theme.Accent, 6)
    MakeCorner(ActiveIndicator, 2)
    ActiveIndicator.Visible = false

    TabButtons[btn] = page

    btn.MouseButton1Click:Connect(function()
        SetPage(page)
        for b, _ in pairs(TabButtons) do
            b:FindFirstChild("Frame").Visible = (b == btn)
        end
    end)

    btn.MouseEnter:Connect(function()
        if ActiveTab ~= page then
            Tween(btn, {BackgroundColor3 = Theme.Tertiary}, 0.12)
        end
    end)
    btn.MouseLeave:Connect(function()
        if ActiveTab ~= page then
            Tween(btn, {BackgroundColor3 = Theme.TabInactive}, 0.12)
        end
    end)

    if #Pages == 1 then SetPage(page) end

    local Tab = {}

    local function SectionFrame(title)
        local wrapper = Frame(page, UDim2.new(1, 0, 0, 0), UDim2.new(0,0,0,0), Theme.Secondary)
        wrapper.AutomaticSize = Enum.AutomaticSize.Y
        MakeCorner(wrapper, 10)
        MakeStroke(wrapper, Theme.Border, 1)

        local inner = Frame(wrapper, UDim2.new(1, 0, 0, 0), UDim2.new(0,0,0,0), Theme.Secondary)
        inner.BackgroundTransparency = 1
        inner.AutomaticSize = Enum.AutomaticSize.Y

        local innerList = Instance.new("UIListLayout")
        innerList.SortOrder = Enum.SortOrder.LayoutOrder
        innerList.Padding   = UDim.new(0, 2)
        innerList.Parent    = inner

        MakePadding(inner, 6, 8, 10, 10)

        if title then
            local secHead = Frame(inner, UDim2.new(1, 0, 0, 28), UDim2.new(0,0,0,0), Theme.Tertiary)
            secHead.AutomaticSize = Enum.AutomaticSize.None
            MakeCorner(secHead, 7)

            local secLabel = Label(secHead, title, 12, Theme.TextDim, Enum.Font.GothamBold, Enum.TextXAlignment.Left)
            secLabel.Position = UDim2.new(0, 8, 0.5, -7)
            secLabel.Size     = UDim2.new(1, -16, 0, 14)
        end

        inner.Parent = wrapper
        return inner
    end

    function Tab:Section(title)
        local section = {}
        local container = SectionFrame(title)

        function section:Button(config)
            local c = config or {}
            local row = Frame(container, UDim2.new(1, 0, 0, 36), UDim2.new(0,0,0,0), Theme.Tertiary)
            row.AutomaticSize = Enum.AutomaticSize.None
            MakeCorner(row, 8)

            local lbl = Label(row, c.Name or "Button", 13, Theme.Text, Enum.Font.GothamBold)
            lbl.Position = UDim2.new(0, 10, 0, 0)
            lbl.Size     = UDim2.new(0.6, 0, 1, 0)
            lbl.TextYAlignment = Enum.TextYAlignment.Center

            local execBtn = Button(row, c.Label or "Execute", UDim2.new(0, 80, 0, 24), UDim2.new(1, -90, 0.5, -12))
            MakeCorner(execBtn, 6)
            execBtn.BackgroundColor3 = Theme.Accent

            execBtn.MouseEnter:Connect(function() Tween(execBtn, {BackgroundColor3 = Theme.AccentHover}, 0.12) end)
            execBtn.MouseLeave:Connect(function() Tween(execBtn, {BackgroundColor3 = Theme.Accent}, 0.12) end)
            execBtn.MouseButton1Click:Connect(function()
                Tween(execBtn, {BackgroundColor3 = Theme.AccentDark}, 0.08)
                task.delay(0.08, function() Tween(execBtn, {BackgroundColor3 = Theme.Accent}, 0.12) end)
                if c.Callback then c.Callback() end
            end)
        end

        function section:Toggle(config)
            local c   = config or {}
            local val = c.Default or false
            local row = Frame(container, UDim2.new(1, 0, 0, 36), UDim2.new(0,0,0,0), Theme.Tertiary)
            row.AutomaticSize = Enum.AutomaticSize.None
            MakeCorner(row, 8)

            local lbl = Label(row, c.Name or "Toggle", 13, Theme.Text, Enum.Font.GothamBold)
            lbl.Position       = UDim2.new(0, 10, 0, 0)
            lbl.Size           = UDim2.new(0.7, 0, 1, 0)
            lbl.TextYAlignment = Enum.TextYAlignment.Center

            local track = Frame(row, UDim2.new(0, 42, 0, 22), UDim2.new(1, -52, 0.5, -11), val and Theme.Toggle_ON or Theme.Toggle_OFF)
            MakeCorner(track, 11)

            local knob = Frame(track, UDim2.new(0, 16, 0, 16), UDim2.new(0, val and 23 or 3, 0.5, -8), Color3.new(1,1,1))
            MakeCorner(knob, 8)

            local function SetToggle(v)
                val = v
                Tween(track, {BackgroundColor3 = v and Theme.Toggle_ON or Theme.Toggle_OFF}, 0.2)
                Tween(knob,  {Position = UDim2.new(0, v and 23 or 3, 0.5, -8)}, 0.2)
                if c.Callback then c.Callback(v) end
            end

            track.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then SetToggle(not val) end
            end)
            row.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then SetToggle(not val) end
            end)

            local ctrl = {}
            function ctrl:Set(v) SetToggle(v) end
            function ctrl:Get() return val end
            return ctrl
        end

        function section:Slider(config)
            local c   = config or {}
            local min = c.Min or 0
            local max = c.Max or 100
            local val = c.Default or min
            local suf = c.Suffix or ""

            local wrapper = Frame(container, UDim2.new(1, 0, 0, 54), UDim2.new(0,0,0,0), Theme.Tertiary)
            wrapper.AutomaticSize = Enum.AutomaticSize.None
            MakeCorner(wrapper, 8)

            local topRow = Frame(wrapper, UDim2.new(1, -20, 0, 22), UDim2.new(0, 10, 0, 6), Theme.Tertiary)
            topRow.BackgroundTransparency = 1

            local nameLbl = Label(topRow, c.Name or "Slider", 13, Theme.Text, Enum.Font.GothamBold)
            nameLbl.Size = UDim2.new(0.7, 0, 1, 0)

            local valLbl = Label(topRow, tostring(val) .. suf, 12, Theme.Accent, Enum.Font.GothamBold, Enum.TextXAlignment.Right)
            valLbl.Size     = UDim2.new(0.3, 0, 1, 0)
            valLbl.Position = UDim2.new(0.7, 0, 0, 0)

            local track = Frame(wrapper, UDim2.new(1, -20, 0, 6), UDim2.new(0, 10, 0, 36), Theme.Slider_BG)
            MakeCorner(track, 3)

            local fill = Frame(track, UDim2.new((val-min)/(max-min), 0, 1, 0), UDim2.new(0,0,0,0), Theme.Slider_Fill)
            MakeCorner(fill, 3)
            MakeGradient(fill, {
                ColorSequenceKeypoint.new(0, Theme.Accent),
                ColorSequenceKeypoint.new(1, Theme.AccentHover),
            }, 0)

            local knob = Frame(fill, UDim2.new(0, 14, 0, 14), UDim2.new(1, -7, 0.5, -7), Color3.new(1,1,1))
            MakeCorner(knob, 7)
            MakeStroke(knob, Theme.Accent, 2)

            local dragging = false
            local function Update(x)
                local abs   = track.AbsolutePosition.X
                local wid   = track.AbsoluteSize.X
                local ratio = math.clamp((x - abs) / wid, 0, 1)
                val = math.floor(min + (max - min) * ratio)
                Tween(fill, {Size = UDim2.new(ratio, 0, 1, 0)}, 0.05)
                valLbl.Text = tostring(val) .. suf
                if c.Callback then c.Callback(val) end
            end

            track.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = true
                    Update(i.Position.X)
                end
            end)
            UserInputService.InputChanged:Connect(function(i)
                if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
                    Update(i.Position.X)
                end
            end)
            UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
            end)

            local ctrl = {}
            function ctrl:Set(v) val = v Update(track.AbsolutePosition.X + (v-min)/(max-min)*track.AbsoluteSize.X) end
            function ctrl:Get() return val end
            return ctrl
        end

        function section:Dropdown(config)
            local c     = config or {}
            local items = c.Items or {}
            local sel   = c.Default or (items[1] or "Select...")
            local open  = false

            local wrapper = Frame(container, UDim2.new(1, 0, 0, 36), UDim2.new(0,0,0,0), Theme.Tertiary)
            wrapper.ClipsDescendants = false
            MakeCorner(wrapper, 8)

            local nameLbl = Label(wrapper, c.Name or "Dropdown", 13, Theme.Text, Enum.Font.GothamBold)
            nameLbl.Position       = UDim2.new(0, 10, 0, 0)
            nameLbl.Size           = UDim2.new(0.5, 0, 1, 0)
            nameLbl.TextYAlignment = Enum.TextYAlignment.Center

            local selBtn = Button(wrapper, sel .. " ▾", UDim2.new(0, 140, 0, 26), UDim2.new(1, -150, 0.5, -13))
            selBtn.BackgroundColor3 = Theme.Dropdown_BG
            selBtn.TextSize         = 12
            selBtn.TextXAlignment   = Enum.TextXAlignment.Center
            MakeCorner(selBtn, 6)
            MakeStroke(selBtn, Theme.Border)

            local dropList = Frame(wrapper, UDim2.new(0, 140, 0, 0), UDim2.new(1, -150, 1, 4), Theme.Dropdown_BG)
            dropList.ClipsDescendants = true
            dropList.ZIndex           = 20
            MakeCorner(dropList, 6)
            MakeStroke(dropList, Theme.Border)

            local dList = Instance.new("UIListLayout")
            dList.SortOrder = Enum.SortOrder.LayoutOrder
            dList.Padding   = UDim.new(0, 2)
            dList.Parent    = dropList
            MakePadding(dropList, 4, 4, 4, 4)

            for _, item in ipairs(items) do
                local ib = Button(dropList, item, UDim2.new(1, 0, 0, 26))
                ib.BackgroundColor3 = Theme.Dropdown_Item
                ib.TextSize         = 12
                ib.TextXAlignment   = Enum.TextXAlignment.Left
                ib.ZIndex           = 21
                MakeCorner(ib, 5)
                MakePadding(ib, 0, 0, 8, 4)

                ib.MouseEnter:Connect(function() Tween(ib, {BackgroundColor3 = Theme.Tertiary}, 0.1) end)
                ib.MouseLeave:Connect(function() Tween(ib, {BackgroundColor3 = Theme.Dropdown_Item}, 0.1) end)
                ib.MouseButton1Click:Connect(function()
                    sel = item
                    selBtn.Text = sel .. " ▾"
                    open = false
                    Tween(dropList, {Size = UDim2.new(0, 140, 0, 0)}, 0.15)
                    if c.Callback then c.Callback(sel) end
                end)
            end

            selBtn.MouseButton1Click:Connect(function()
                open = not open
                local targetH = open and math.min(#items * 30 + 8, 160) or 0
                Tween(dropList, {Size = UDim2.new(0, 140, 0, targetH)}, 0.2)
            end)

            local ctrl = {}
            function ctrl:Get() return sel end
            function ctrl:Set(v) sel = v selBtn.Text = v .. " ▾" end
            function ctrl:Refresh(newItems)
                items = newItems
                for _, ch in ipairs(dropList:GetChildren()) do
                    if ch:IsA("TextButton") then ch:Destroy() end
                end
                for _, item in ipairs(items) do
                    local ib = Button(dropList, item, UDim2.new(1, 0, 0, 26))
                    ib.BackgroundColor3 = Theme.Dropdown_Item
                    ib.TextSize = 12
                    ib.TextXAlignment = Enum.TextXAlignment.Left
                    ib.ZIndex = 21
                    MakeCorner(ib, 5)
                    MakePadding(ib, 0, 0, 8, 4)
                    ib.MouseButton1Click:Connect(function()
                        sel = item
                        selBtn.Text = sel .. " ▾"
                        open = false
                        Tween(dropList, {Size = UDim2.new(0, 140, 0, 0)}, 0.15)
                        if c.Callback then c.Callback(sel) end
                    end)
                end
            end
            return ctrl
        end

        function section:Input(config)
            local c   = config or {}
            local val = c.Default or ""

            local wrapper = Frame(container, UDim2.new(1, 0, 0, 54), UDim2.new(0,0,0,0), Theme.Tertiary)
            wrapper.AutomaticSize = Enum.AutomaticSize.None
            MakeCorner(wrapper, 8)

            local nameLbl = Label(wrapper, c.Name or "Input", 13, Theme.Text, Enum.Font.GothamBold)
            nameLbl.Position       = UDim2.new(0, 10, 0, 4)
            nameLbl.Size           = UDim2.new(1, -20, 0, 16)
            nameLbl.TextYAlignment = Enum.TextYAlignment.Top

            local box = Instance.new("TextBox")
            box.Size                = UDim2.new(1, -20, 0, 26)
            box.Position            = UDim2.new(0, 10, 0, 24)
            box.BackgroundColor3    = Theme.Input_BG
            box.TextColor3          = Theme.Text
            box.PlaceholderText     = c.Placeholder or "Type here..."
            box.PlaceholderColor3   = Theme.TextMuted
            box.Text                = val
            box.TextSize            = 13
            box.Font                = Enum.Font.Gotham
            box.BorderSizePixel     = 0
            box.ClearTextOnFocus    = c.ClearOnFocus or false
            box.Parent              = wrapper
            MakeCorner(box, 6)
            MakeStroke(box, Theme.Border)
            MakePadding(box, 0, 0, 8, 4)

            box.Focused:Connect(function() MakeStroke(box, Theme.Accent) end)
            box.FocusLost:Connect(function(enter)
                MakeStroke(box, Theme.Border)
                val = box.Text
                if c.Callback then c.Callback(val, enter) end
            end)

            local ctrl = {}
            function ctrl:Get() return box.Text end
            function ctrl:Set(v) box.Text = v val = v end
            return ctrl
        end

        function section:ColorPicker(config)
            local c   = config or {}
            local val = c.Default or Color3.fromRGB(255, 255, 255)
            local open = false
            local h, s, v2 = Color3.toHSV(val)

            local wrapper = Frame(container, UDim2.new(1, 0, 0, 36), UDim2.new(0,0,0,0), Theme.Tertiary)
            wrapper.ClipsDescendants = false
            MakeCorner(wrapper, 8)

            local nameLbl = Label(wrapper, c.Name or "Color", 13, Theme.Text, Enum.Font.GothamBold)
            nameLbl.Position       = UDim2.new(0, 10, 0, 0)
            nameLbl.Size           = UDim2.new(0.6, 0, 1, 0)
            nameLbl.TextYAlignment = Enum.TextYAlignment.Center

            local preview = Frame(wrapper, UDim2.new(0, 26, 0, 26), UDim2.new(1, -36, 0.5, -13), val)
            MakeCorner(preview, 6)
            MakeStroke(preview, Theme.Border)

            local picker = Frame(wrapper, UDim2.new(0, 200, 0, 0), UDim2.new(1, -210, 1, 4), Theme.ColorPicker_BG)
            picker.ClipsDescendants = true
            picker.ZIndex = 22
            MakeCorner(picker, 8)
            MakeStroke(picker, Theme.Border)

            local function UpdateColor()
                val = Color3.fromHSV(h, s, v2)
                preview.BackgroundColor3 = val
                if c.Callback then c.Callback(val) end
            end

            local hueBar = Frame(picker, UDim2.new(1, -16, 0, 14), UDim2.new(0, 8, 0, 8), Color3.new(1,1,1))
            hueBar.ZIndex = 23
            MakeCorner(hueBar, 3)
            MakeGradient(hueBar, {
                ColorSequenceKeypoint.new(0,    Color3.fromRGB(255,0,0)),
                ColorSequenceKeypoint.new(0.17, Color3.fromRGB(255,255,0)),
                ColorSequenceKeypoint.new(0.33, Color3.fromRGB(0,255,0)),
                ColorSequenceKeypoint.new(0.5,  Color3.fromRGB(0,255,255)),
                ColorSequenceKeypoint.new(0.67, Color3.fromRGB(0,0,255)),
                ColorSequenceKeypoint.new(0.83, Color3.fromRGB(255,0,255)),
                ColorSequenceKeypoint.new(1,    Color3.fromRGB(255,0,0)),
            }, 0)

            local hueKnob = Frame(hueBar, UDim2.new(0, 4, 1, 4), UDim2.new(h, -2, 0, -2), Color3.new(1,1,1))
            hueKnob.ZIndex = 24
            MakeCorner(hueKnob, 2)
            MakeStroke(hueKnob, Theme.Background, 1)

            local svField = Frame(picker, UDim2.new(1, -16, 0, 80), UDim2.new(0, 8, 0, 28), Color3.fromHSV(h, 1, 1))
            svField.ZIndex = 23
            MakeCorner(svField, 4)

            local svKnob = Frame(svField, UDim2.new(0, 10, 0, 10), UDim2.new(s, -5, 1-v2, -5), Color3.new(1,1,1))
            svKnob.ZIndex = 24
            MakeCorner(svKnob, 5)
            MakeStroke(svKnob, Theme.Background, 1)

            local draggingH, draggingS = false, false

            hueBar.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then
                    draggingH = true
                    h = math.clamp((i.Position.X - hueBar.AbsolutePosition.X) / hueBar.AbsoluteSize.X, 0, 1)
                    hueKnob.Position = UDim2.new(h, -2, 0, -2)
                    svField.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
                    UpdateColor()
                end
            end)
            svField.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then
                    draggingS = true
                    s  = math.clamp((i.Position.X - svField.AbsolutePosition.X) / svField.AbsoluteSize.X, 0, 1)
                    v2 = 1 - math.clamp((i.Position.Y - svField.AbsolutePosition.Y) / svField.AbsoluteSize.Y, 0, 1)
                    svKnob.Position = UDim2.new(s, -5, 1-v2, -5)
                    UpdateColor()
                end
            end)
            UserInputService.InputChanged:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseMovement then
                    if draggingH then
                        h = math.clamp((i.Position.X - hueBar.AbsolutePosition.X) / hueBar.AbsoluteSize.X, 0, 1)
                        hueKnob.Position = UDim2.new(h, -2, 0, -2)
                        svField.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
                        UpdateColor()
                    end
                    if draggingS then
                        s  = math.clamp((i.Position.X - svField.AbsolutePosition.X) / svField.AbsoluteSize.X, 0, 1)
                        v2 = 1 - math.clamp((i.Position.Y - svField.AbsolutePosition.Y) / svField.AbsoluteSize.Y, 0, 1)
                        svKnob.Position = UDim2.new(s, -5, 1-v2, -5)
                        UpdateColor()
                    end
                end
            end)
            UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then
                    draggingH = false
                    draggingS = false
                end
            end)

            preview.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then
                    open = not open
                    Tween(picker, {Size = UDim2.new(0, 200, 0, open and 120 or 0)}, 0.2)
                end
            end)

            local ctrl = {}
            function ctrl:Get() return val end
            function ctrl:Set(color)
                val = color
                h, s, v2 = Color3.toHSV(color)
                preview.BackgroundColor3 = color
            end
            return ctrl
        end

        function section:Keybind(config)
            local c     = config or {}
            local key   = c.Default or Enum.KeyCode.Unknown
            local listen = false

            local wrapper = Frame(container, UDim2.new(1, 0, 0, 36), UDim2.new(0,0,0,0), Theme.Tertiary)
            wrapper.AutomaticSize = Enum.AutomaticSize.None
            MakeCorner(wrapper, 8)

            local nameLbl = Label(wrapper, c.Name or "Keybind", 13, Theme.Text, Enum.Font.GothamBold)
            nameLbl.Position       = UDim2.new(0, 10, 0, 0)
            nameLbl.Size           = UDim2.new(0.6, 0, 1, 0)
            nameLbl.TextYAlignment = Enum.TextYAlignment.Center

            local keyBtn = Button(wrapper, key.Name, UDim2.new(0, 90, 0, 24), UDim2.new(1, -100, 0.5, -12))
            keyBtn.BackgroundColor3 = Theme.Keybind_BG
            keyBtn.TextSize         = 12
            keyBtn.Font             = Enum.Font.GothamBold
            MakeCorner(keyBtn, 6)
            MakeStroke(keyBtn, Theme.Border)

            keyBtn.MouseButton1Click:Connect(function()
                listen          = true
                keyBtn.Text     = "..."
                keyBtn.TextColor3 = Theme.Accent
            end)
            UserInputService.InputBegan:Connect(function(i, gpe)
                if gpe then return end
                if listen and i.UserInputType == Enum.UserInputType.Keyboard then
                    key              = i.KeyCode
                    keyBtn.Text      = key.Name
                    keyBtn.TextColor3= Theme.Text
                    listen           = false
                    if c.Callback then c.Callback(key) end
                end
            end)

            local ctrl = {}
            function ctrl:Get() return key end
            function ctrl:Set(k) key = k keyBtn.Text = k.Name end
            return ctrl
        end

        function section:Label(config)
            local c = config or {}
            local row = Frame(container, UDim2.new(1, 0, 0, 28), UDim2.new(0,0,0,0), Color3.new(0,0,0))
            row.BackgroundTransparency = 1
            local lbl = Label(row, c.Text or "Label", c.Size or 13, c.Color or Theme.TextDim, Enum.Font.Gotham)
            lbl.Position       = UDim2.new(0, 6, 0, 0)
            lbl.Size           = UDim2.new(1, -12, 1, 0)
            lbl.TextYAlignment = Enum.TextYAlignment.Center

            local ctrl = {}
            function ctrl:Set(text) lbl.Text = text end
            function ctrl:Get() return lbl.Text end
            return ctrl
        end

        function section:Separator()
            local line = Frame(container, UDim2.new(1, 0, 0, 1), UDim2.new(0,0,0,0), Theme.Border)
        end

        function section:Notification(text, ntype)
            local colors = {info = Theme.Accent, success = Theme.Success, warning = Theme.Warning, error = Theme.Danger}
            local color  = colors[ntype or "info"] or Theme.Accent

            local notif = Frame(ScreenGui, UDim2.new(0, 260, 0, 52),
                UDim2.new(1, -270, 1, 60), color)
            notif.ZIndex = 200
            MakeCorner(notif, 10)
            MakeStroke(notif, Color3.new(1,1,1), 1, 0.85)

            local msg = Label(notif, text or "", 13, Color3.new(1,1,1), Enum.Font.GothamBold)
            msg.Position       = UDim2.new(0, 12, 0, 0)
            msg.Size           = UDim2.new(1, -24, 1, 0)
            msg.TextYAlignment = Enum.TextYAlignment.Center
            msg.TextWrapped    = true
            msg.ZIndex         = 201

            Tween(notif, {Position = UDim2.new(1, -270, 1, -62)}, 0.3, Enum.EasingStyle.Back)
            task.delay(3, function()
                Tween(notif, {Position = UDim2.new(1, 10, 1, -62)}, 0.3)
                task.delay(0.35, function() notif:Destroy() end)
            end)
        end

        return section
    end

    return Tab
end

local draggingWindow  = false
local dragStartPos    = nil
local dragStartFrame  = nil

TitleBar.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 then
        draggingWindow = true
        dragStartPos   = i.Position
        dragStartFrame = MainFrame.Position
    end
end)
UserInputService.InputChanged:Connect(function(i)
    if draggingWindow and i.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = i.Position - dragStartPos
        MainFrame.Position = UDim2.new(
            dragStartFrame.X.Scale,
            dragStartFrame.X.Offset + delta.X,
            dragStartFrame.Y.Scale,
            dragStartFrame.Y.Offset + delta.Y
        )
    end
end)
UserInputService.InputEnded:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 then
        draggingWindow = false
    end
end)

local minimized = false
local savedH    = H
MinBtn.MouseButton1Click:Connect(function()
    minimized = not minimized
    if minimized then
        savedH = MainFrame.AbsoluteSize.Y
        Tween(MainFrame, {Size = UDim2.new(0, W, 0, TH+2)}, 0.3)
        ContentArea.Visible = false
        Sidebar.Visible     = false
        SideVLine.Visible   = false
        TitleLine.Visible   = false
        MinBtn.Text         = "□"
    else
        Tween(MainFrame, {Size = UDim2.new(0, W, 0, savedH)}, 0.3)
        task.delay(0.2, function()
            ContentArea.Visible = true
            Sidebar.Visible     = true
            SideVLine.Visible   = true
            TitleLine.Visible   = true
        end)
        MinBtn.Text = "—"
    end
end)

CloseBtn.MouseEnter:Connect(function() Tween(CloseBtn, {BackgroundColor3 = Color3.fromRGB(80,30,30)}, 0.1) end)
CloseBtn.MouseLeave:Connect(function() Tween(CloseBtn, {BackgroundColor3 = Color3.fromRGB(60,30,30)}, 0.1) end)
CloseBtn.MouseButton1Click:Connect(function()
    Tween(MainFrame, {Size = UDim2.new(0, W, 0, 0)}, 0.25, Enum.EasingStyle.Back, Enum.EasingDirection.In)
    Tween(MainFrame, {BackgroundTransparency = 1}, 0.2)
    task.delay(0.3, function() ScreenGui:Destroy() end)
end)

UserInputService.InputBegan:Connect(function(i, gpe)
    if gpe then return end
    if i.KeyCode == Enum.KeyCode.RightControl then
        MainFrame.Visible = not MainFrame.Visible
        MainShadow.Visible = MainFrame.Visible
    end
end)

local function PlayIntro()
    Tween(SplashFrame, {Position = UDim2.new(0.5, -110, 0.5, -35)}, 0.55, Enum.EasingStyle.Back, Enum.EasingDirection.Out)

    task.delay(0.6, function()
        Tween(SplashLine, {Size = UDim2.new(1, 0, 0, 2)}, 0.4)
    end)

    task.delay(2.2, function()
        local left  = Frame(SplashHolder, UDim2.new(0, 220, 0, 70), UDim2.new(0.5, -110, 0.5, -35), Theme.Background)
        left.ZIndex = 112
        MakeCorner(left, 14)
        MakeStroke(left, Theme.Accent, 1.5)
        left.ClipsDescendants = true

        local right = Frame(SplashHolder, UDim2.new(0, 0, 0, 70), UDim2.new(0.5, -110, 0.5, -35), Theme.Background)
        right.ZIndex = 112
        MakeCorner(right, 14)
        MakeStroke(right, Theme.Accent, 1.5)
        right.ClipsDescendants = true

        Tween(SplashFrame, {BackgroundTransparency = 1}, 0.01)
        SplashLogo.Parent  = nil
        SplashTitle.Parent = nil
        SplashSub.Parent   = nil
        SplashLine.Parent  = nil

        Tween(left,  {Position = UDim2.new(0.5, -380, 0.5, -35), Size = UDim2.new(0, 260, 0, 70)}, 0.5, Enum.EasingStyle.Back, Enum.EasingDirection.In)
        Tween(right, {Position = UDim2.new(0.5, 110,  0.5, -35), Size = UDim2.new(0, 260, 0, 70)}, 0.5, Enum.EasingStyle.Back, Enum.EasingDirection.In)

        task.delay(0.5, function()
            SplashHolder:Destroy()
            MainShadow.Visible = true
            MainFrame.Visible  = true
            MainFrame.Size     = UDim2.new(0, 0, 0, 0)
            Tween(MainFrame, {Size = UDim2.new(0, W, 0, H)}, 0.45, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
        end)
    end)
end

PlayIntro()

NexusLib.AddTab     = AddTab
NexusLib.SetTheme   = function(t) for k, v in pairs(t) do if Theme[k] then Theme[k] = v end end end
NexusLib.GetTheme   = function() return Theme end
NexusLib.Destroy    = function() ScreenGui:Destroy() end
NexusLib.Toggle     = function() MainFrame.Visible = not MainFrame.Visible end
NexusLib.SetTitle   = function(t) TitleText.Text = t TitleSub2.Text = "" end
NexusLib.SetLogo    = function(id) TitleLogo.Image = id SplashLogo.Image = id end
NexusLib.Minimize   = function() MinBtn.MouseButton1Click:Fire() end
NexusLib.Keybind    = Enum.KeyCode.RightControl

return NexusLib
